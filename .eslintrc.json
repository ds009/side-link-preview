{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "globals": {
    "chrome": "readonly",
    "SLP_I18N": "readonly",
    "normalizeSlpSettings": "readonly",
    "activeDomainList": "readonly",
    "matchDomain": "readonly",
    "isHostDisabledByScope": "readonly",
    "isUrlDisabledByScope": "readonly",
    "matchScopePattern": "readonly",
    "scopeEntryForUrl": "readonly",
    "probeEmbedBlock": "readonly",
    "isSensitiveAuthPreviewUrl": "readonly",
    "isSensitivePreviewUrl": "readonly",
    "isSensitivePreviewHost": "readonly",
    "isSensitivePreviewPath": "readonly",
    "isRestrictedPublicSuffixHost": "readonly",
    "isIpHostname": "readonly",
    "isNativeOnlyHost": "readonly",
    "isNativeOnlyPreviewUrl": "readonly",
    "LOCALE_LABELS": "readonly",
    "SUPPORTED_LOCALES": "readonly",
    "detectBrowserLocale": "readonly",
    "urlOnScopeList": "readonly",
    "prepareScopeListAppend": "readonly",
    "settingsByteLength": "readonly",
    "settingsToSyncPayload": "readonly",
    "SYNC_ITEM_SOFT_LIMIT": "readonly",
    "pickNewerSettings": "readonly",
    "readSettingsRev": "readonly",
    "parseScopePattern": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": ["error", "smart"],
    "no-console": "off"
  },
  "ignorePatterns": [
    "dist/",
    "icons/",
    "node_modules/",
    "store-assets/"
  ],
  "overrides": [
    {
      "files": ["settings-shared.js"],
      "env": {
        "node": true
      },
      "rules": {
        "no-unused-vars": "off"
      }
    },
    {
      "files": ["embed-probe.js"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
